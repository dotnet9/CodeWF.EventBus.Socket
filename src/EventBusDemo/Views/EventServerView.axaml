<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EventBusDemo.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:log="https://codewf.com"
        prism:ViewModelLocator.AutoWireViewModel="True"
        mc:Ignorable="d"
        d:DesignWidth="860"
        d:DesignHeight="500"
        Width="860"
        Height="500"
        Padding="20"
        WindowStartupLocation="CenterScreen"
        x:Class="EventBusDemo.Views.EventServerView"
        x:DataType="vm:EventServerViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding Title}">
    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Width" Value="80" />
            <Setter Property="Height" Value="35" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </Window.Styles>
    <Grid RowDefinitions="Auto,*">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="10">
            <TextBlock Text="事件服务地址：" VerticalAlignment="Center" Width="110" />
            <TextBox Text="{Binding Address}"
                     Width="240"
                     TextWrapping="Wrap"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"/>
            <Button Content="启动"
                    Command="{Binding RunServerAsync}"
                    VerticalAlignment="Center"
                    IsEnabled="{Binding CanStartServer}"
                    Classes="Success"
                    Theme="{DynamicResource SolidButton}"/>
            <Button Content="停止"
                    Command="{Binding Stop}"
                    VerticalAlignment="Center"
                    IsEnabled="{Binding CanStopServer}"
                    Classes="Danger"
                    Theme="{DynamicResource SolidButton}"/>
            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                <Ellipse Width="10"
                         Height="10"
                         Fill="{Binding ServerStatusColor}"
                         Stroke="Transparent"
                         StrokeThickness="1"
                         VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ServerStatusText}"
                           VerticalAlignment="Center"
                           Foreground="{Binding ServerStatusColor}"
                           FontWeight="Medium"/>
            </StackPanel>
        </StackPanel>
        <Border Grid.Row="1" Classes="Hover" Theme="{StaticResource CardBorder}" Padding="8">
            <log:LogView />
        </Border>
    </Grid>
</Window>
