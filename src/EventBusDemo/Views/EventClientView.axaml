<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EventBusDemo.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:log="https://codewf.com"
        prism:ViewModelLocator.AutoWireViewModel="True"
        mc:Ignorable="d"
        d:DesignWidth="1080"
        d:DesignHeight="820"
        Width="1080"
        Height="820"
        Padding="20"
        WindowStartupLocation="CenterScreen"
        x:Class="EventBusDemo.Views.EventClientView"
        x:DataType="vm:EventClientViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding Title}">
    <Grid RowDefinitions="Auto,Auto,Auto,1*" ColumnDefinitions="1*" ColumnSpacing="10" RowSpacing="15">
        <Border Grid.Row="0" Padding="12" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,1*,Auto,Auto" ColumnSpacing="10">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="事件服务地址：" VerticalAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Address}" VerticalAlignment="Center" FontWeight="Bold" />
                <Button Grid.Row="0" Grid.Column="2" Content="连接" Command="{Binding ConnectServerAsync}" Width="80" />
                <Button Grid.Row="0" Grid.Column="3" Content="断开" Command="{Binding DisconnectAsync}" Width="80" />
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0 8 0 0">
                    <Ellipse Width="12" Height="12" Fill="{Binding ConnectStatusColor}" Margin="0 0 8 0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ConnectStatusText}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="12" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="订阅 / 取消订阅" FontWeight="Bold" Margin="0 0 0 8" />
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10">
                    <CheckBox Content="库存预警命令" IsChecked="{Binding IsSubscribeInventoryAlertCommand}" Command="{Binding SubscribeOrUnsubscribeInventoryAlertCommand}" />
                    <CheckBox Grid.Column="1" Content="门店营运播报" IsChecked="{Binding IsSubscribeStoreStatusCommand}" Command="{Binding SubscribeOrUnsubscribeStoreStatusCommand}" />
                    <CheckBox Grid.Column="2" Content="销售快照查询" IsChecked="{Binding IsSubscribeSalesSnapshotQuery}" Command="{Binding SubscribeOrUnsubscribeSalesSnapshotQuery}" />
                    <CheckBox Grid.Column="3" Content="服务时钟查询" IsChecked="{Binding IsSubscribeServiceClockQuery}" Command="{Binding SubscribeOrUnsubscribeServiceClockQuery}" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Padding="12" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="发布命令 / 发起查询" FontWeight="Bold" Margin="0 0 0 8" />
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10">
                    <Button Content="发布库存预警" Command="{Binding PublishInventoryAlertCommand}" Width="150" />
                    <Button Grid.Column="1" Content="发布营运播报" Command="{Binding PublishStoreStatusCommand}" Width="150" />
                    <Button Grid.Column="2" Content="查询销售快照" Command="{Binding QuerySalesSnapshot}" Width="130" />
                    <Button Grid.Column="3" Content="查询服务时钟" Command="{Binding QueryServiceClock}" Width="130" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Padding="12" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
            <Grid RowDefinitions="Auto,1*">
                <TextBlock Text="事件日志" FontWeight="Bold" Margin="0 0 0 8" />
                <log:LogView Grid.Row="1" />
            </Grid>
        </Border>
    </Grid>
</Window>
